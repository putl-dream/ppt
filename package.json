{
  "name": "agent-ppt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --exclude tests/*.integration.test.ts",
    "test:integration:agent": "vitest run tests/agent-gateway.integration.test.ts",
    "test:integration:workflow": "vitest run tests/agent-workflow.integration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.5",
    "openai": "^6.42.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rotating-file-stream": "^3.2.9",
    "zod": "^4.1.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.4.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
