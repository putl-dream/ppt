# Developer diagnostics only.
# Model credentials, endpoints, timeout, and fallback belong in Settings → 模型 / 工作流.
AGENT_LOG_LEVEL=info
# AGENT_LOG_FILE=false
# AGENT_LOG_DETAIL=minimal

# Advanced CI / integration overrides (optional; not used by the desktop UI):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AGENT_TIMEOUT_MS=600000
# AGENT_MAX_OUTPUT_TOKENS=16384
# AGENT_CONTEXT_TOKEN_THRESHOLD=100000

# Web search (optional; can also be configured in Settings → 生成参数):
# TAVILY_API_KEY=
# TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
