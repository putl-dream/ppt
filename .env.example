# The settings dialog can provide the API key at runtime instead.
AGENT_TIMEOUT_MS=600000
AGENT_MAX_OUTPUT_TOKENS=2048
AGENT_LOG_LEVEL=info
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-5.5
